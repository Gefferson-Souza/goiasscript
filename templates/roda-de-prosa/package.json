{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "{{projeto_descricao}} - Framework Roda de Prosa (Clean Architecture Goiana)",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev-server.js",
    "build": "bun run scripts/build.js",
    "start": "bun run scripts/serve.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bun run lint:check",
    "lint:check": "echo '🇧🇷 Verificando código goiano...' && echo '✅ Código tá fichinha!'",
    "clean": "rm -rf dist/",
    "gerar:entidade": "bun run scripts/generators/entidade.js",
    "gerar:caso_de_uso": "bun run scripts/generators/caso_de_uso.js",
    "gerar:controlador": "bun run scripts/generators/controlador.js",
    "gerar:componente": "bun run scripts/generators/componente.js"
  },
  "keywords": [
    "goiasscript",
    "clean-architecture",
    "bun",
    "framework",
    "fullstack",
    "brasil"
  ],
  "author": "{{autor_nome}}",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.15",
    "postcss": "^8.4.29"
  },
  "dependencies": {
    "express": "^4.18.2",
    "chokidar": "^3.5.3",
    "ws": "^8.13.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "trustedDependencies": [
    "@types/bun"
  ],
  "roda_de_prosa": {
    "framework": "Clean Architecture Goiana",
    "versao": "1.0.0",
    "arquitetura": {
      "cores": "Lógica de negócio pura",
      "chao_de_fabrica": "Infraestrutura e adaptadores",
      "terreiro_da_prosa": "Interface do usuário",
      "balaios_compartilhados": "Utilitários compartilhados"
    },
    "comandos_goianos": {
      "bun run dev": "Bota o servidor pra moer (desenvolvimento)",
      "bun run build": "Arruma o trem pra produção",
      "bun run start": "Roda o bagulho em produção",
      "bun test": "Testa se tá funcionando",
      "bun run gerar:entidade": "Cria uma entidade nova",
      "bun run gerar:caso_de_uso": "Cria um caso de uso novo"
    }
  }
}