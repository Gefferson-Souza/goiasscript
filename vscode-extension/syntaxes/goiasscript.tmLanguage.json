		  {
			"name": "entity.name.type.goiasscript",
			"match": "(?<=:\\s*)\\b(texto|numero|booleano|lista|objeto|funcao|coisa|nada)\\b"
		  }
		]
	  }
	},
	"scopeName": "source.gs"
