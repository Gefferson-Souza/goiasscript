		"patterns": [
		  {
			"name": "comment.line.double-slash.goiasscript",
			"match": "//.*$"
		  },
		  {
			"begin": "/\\*",
			"end": "\\*/",
			"name": "comment.block.goiasscript"
		  }
		]
	  },
	  "strings": {
		"name": "string.quoted.double.goiasscript",
		"begin": "\"",
		"end": "\"",
