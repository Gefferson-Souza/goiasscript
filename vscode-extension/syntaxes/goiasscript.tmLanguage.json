			"begin": "(?<=\\bde\\s+)\"",
			"end": "\"",
			"patterns": [
			  {
				"name": "constant.character.escape.goiasscript",
				"match": "\\\\."
			  }
			]
		  }
		]
	  },
	  "types": {
		"patterns": [
		  {
			"name": "storage.type.primitive.goiasscript",
			"match": "\\b(texto|numero|booleano|lista|objeto|funcao|coisa|nada)\\b"
		  },
